}

.dropdown:hover .dropdown-menu{

display:flex;

animation:fadeMenu .25s ease;

}

.dropdown-menu button{

background:transparent;

border:none;

color:white;

text-align:left;

padding:12px;

border-radius:12px;

cursor:pointer;

transition:.3s;

font-size:15px;

}

.dropdown-menu button:hover{

background:rgba(52,211,153,.15);

color:#34D399;

padding-left:18px;

}

@keyframes fadeMenu{

from{

opacity:0;

transform:translateY(10px);

}

to{

opacity:1;

transform:translateY(0);

}






